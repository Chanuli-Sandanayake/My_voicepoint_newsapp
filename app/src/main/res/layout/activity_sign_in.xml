<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#80A850C5"
    tools:context=".SignInActivity">

    <!-- Logo -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="74dp"
        android:layout_height="87dp"
        android:layout_marginTop="84dp"
        android:layout_centerHorizontal="true"
        android:src="@drawable/logo"
        android:contentDescription="@string/app_logo1" />

    <!-- App Subtitle -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="227dp"
        android:layout_height="23dp"
        android:layout_below="@id/logoImage"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="@string/app_subtitle"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="italic"
        android:fontFamily="sans-serif-medium" />

    <!-- Tab Container -->
    <LinearLayout
        android:id="@+id/tabLayout"
        android:layout_width="412dp"
        android:layout_height="48dp"
        android:layout_below="@id/subtitleText"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="70dp"
        android:orientation="horizontal"
        android:background="@drawable/rounded_tab_container">

        <Button
            android:id="@+id/signInTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/rounded_tab_active"
            android:text="@string/sign_in"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textSize="20sp"
            android:fontFamily="sans-serif" />

        <Button
            android:id="@+id/signUpTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="@string/sign_up"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textSize="20sp"
            android:fontFamily="sans-serif" />
    </LinearLayout>

    <!-- White Form Container -->
    <LinearLayout
        android:id="@+id/formContainer"
        android:layout_width="362dp"
        android:layout_height="309dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="350dp"
        android:background="@drawable/rounded_container"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="75dp"
            android:layout_height="30dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif"
            android:text="@string/signin_title"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Username Field -->

        <!-- Password Field -->

        <!-- Login Button -->
        <LinearLayout
            android:layout_width="328dp"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/rounded_textfield"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_user"
                app:tint="#7B6B6B" />

            <EditText
                android:id="@+id/usernameInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="16dp"
                android:background="@null"
                android:fontFamily="sans-serif"
                android:hint="User Name"
                android:textColor="#000000"
                android:textColorHint="#7B6B6B"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="328dp"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/rounded_textfield"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/password"
                app:tint="#7B6B6B" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="16dp"
                android:background="@null"
                android:fontFamily="sans-serif"
                android:hint="Password"
                android:inputType="textPassword"
                android:textColor="#000000"
                android:textColorHint="#7B6B6B"
                android:textSize="20sp" />
        </LinearLayout>

        <Button
            android:id="@+id/loginButton"
            android:layout_width="297dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/rounded_button"
            android:fontFamily="sans-serif"
            android:text="Login"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>
</RelativeLayout>

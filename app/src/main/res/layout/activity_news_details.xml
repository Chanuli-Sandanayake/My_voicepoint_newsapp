<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80A850C5">

    <LinearLayout
        android:id="@+id/detailsContainer"
        android:layout_width="389dp"
        android:layout_height="793dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="19dp"
        android:background="#40000000"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/categoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="5dp"
            android:text="Category"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/newsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Latest News Title"
            android:textColor="#000000"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/newsDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="2025-04-16"
            android:textColor="#000000"
            android:textSize="20sp" />

        <ImageView
            android:id="@+id/newsImage"
            android:layout_width="360dp"
            android:layout_height="282dp"
            android:background="@drawable/rounded_corners"
            android:clipToOutline="true"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/newsDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="News description goes here..."
            android:textColor="#000000"
            android:textSize="16sp" />

        <View
            android:layout_width="360dp"
            android:layout_height="1dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/relatedNewsRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:clipToPadding="false"
            android:overScrollMode="never" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#A850C5"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/navSports"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="25dp"
            android:background="@drawable/sports"
            android:contentDescription="Sports"/>

        <ImageButton
            android:id="@+id/navAcademic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="25dp"
            android:background="@drawable/academic"
            android:contentDescription="Academic"/>

        <ImageButton
            android:id="@+id/navEvents"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="25dp"
            android:background="@drawable/events"
            android:contentDescription="Events"/>

        <ImageButton
            android:id="@+id/navMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="25dp"
            android:background="@drawable/menu"
            android:contentDescription="Menu"/>
    </LinearLayout>
</RelativeLayout>
